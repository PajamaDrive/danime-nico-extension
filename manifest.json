{
  "manifest_version": 3,
  "name": "dアニメ ニコ動コメント拡張",
  "version": "1.0",
  "description": "dアニメストアでニコニコ動画のコメントを流す拡張機能",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://animestore.docomo.ne.jp/*",
    "https://*.nicovideo.jp/*",
    "https://public.nvcomment.nicovideo.jp/*",
    "https://nvapi.nicovideo.jp/*"
  ],
  "action": {
    "default_popup": "dist/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://animestore.docomo.ne.jp/animestore/sc_d_pc*"],
      "js": ["dist/content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  }
}
