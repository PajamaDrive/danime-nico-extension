{
  "name": "danime-nico-extension",
  "version": "1.0.0",
  "description": "dアニメストアでニコニコ動画のコメントを流す拡張機能（TypeScript + Vite版）",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build && vite build -c vite.content.config.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.260",
    "@types/node": "^24.12.0",
    "happy-dom": "^14.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^1.4.0"
  },
  "volta": {
    "node": "24.14.0",
    "npm": "11.12.0"
  }
}
