{
  "name": "danime-nico-extension",
  "version": "1.0.0",
  "description": "dアニメストアでニコニコ動画のコメントを流す拡張機能（TypeScript + Vite版）",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build && vite build -c vite.content.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/chrome": "^0.0.260",
    "@types/node": "^24.12.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "happy-dom": "^14.0.0",
    "prettier": "^3.8.1",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.57.2",
    "vite": "^5.2.0",
    "vitest": "^1.4.0"
  },
  "volta": {
    "node": "24.14.0",
    "npm": "11.12.0"
  }
}
